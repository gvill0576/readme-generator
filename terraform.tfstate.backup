      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "action_group_executor": [
              {
                "custom_control": null,
                "lambda": "arn:aws:lambda:us-east-1:388691194728:function:RepoIntelligenceScannerTool"
              }
            ],
            "action_group_id": "O52LVFI8GX",
            "action_group_name": "ScanRepoAction",
            "action_group_state": "ENABLED",
            "agent_id": "20WLN1NU27",
            "agent_version": "DRAFT",
            "api_schema": [
              {
                "payload": "{\n  \"openapi\": \"3.0.0\",\n  \"info\": {\n    \"title\": \"Repository Intelligence Scanner\",\n    \"version\": \"2.0.0\",\n    \"description\": \"API for performing structured data intelligence analysis on a Git repository.\"\n  },\n  \"paths\": {\n    \"scan-repo\": {\n      \"post\": {\n        \"summary\": \"Performs a deep intelligence scan of a public Git repository.\",\n        \"description\": \"This tool clones a public GitHub repository and returns structured intelligence including file inventory, technology categorization, data engineering technology detection, project maturity scoring, CI/CD pipeline detection, and test coverage signals. Use this when you need to analyze the technical composition and data engineering relevance of a repository.\",\n        \"requestBody\": {\n          \"required\": true,\n          \"content\": {\n            \"application/json\": {\n              \"schema\": {\n                \"type\": \"object\",\n                \"properties\": {\n                  \"repo_url\": {\n                    \"type\": \"string\",\n                    \"description\": \"The full URL of the public GitHub repository to scan.\"\n                  }\n                },\n                \"required\": [\"repo_url\"]\n              }\n            }\n          }\n        },\n        \"responses\": {\n          \"200\": {\n            \"description\": \"Structured repository intelligence data.\",\n            \"content\": {\n              \"application/json\": {\n                \"schema\": {\n                  \"type\": \"object\",\n                  \"properties\": {\n                    \"files\": {\n                      \"type\": \"array\",\n                      \"items\": { \"type\": \"string\" }\n                    },\n                    \"total_file_count\": { \"type\": \"integer\" },\n                    \"extension_breakdown\": { \"type\": \"object\" },\n                    \"category_breakdown\": { \"type\": \"object\" },\n                    \"top_level_directories\": {\n                      \"type\": \"array\",\n                      \"items\": { \"type\": \"string\" }\n                    },\n                    \"max_directory_depth\": { \"type\": \"integer\" },\n                    \"has_ci_cd_pipeline\": { \"type\": \"boolean\" },\n                    \"has_tests\": { \"type\": \"boolean\" },\n                    \"has_documentation\": { \"type\": \"boolean\" },\n                    \"detected_de_technologies\": {\n                      \"type\": \"array\",\n                      \"items\": { \"type\": \"string\" }\n                    },\n                    \"project_maturity_score\": { \"type\": \"integer\" },\n                    \"maturity_out_of\": { \"type\": \"integer\" },\n                    \"repo_url\": { \"type\": \"string\" }\n                  }\n                }\n              }\n            }\n          }\n        }\n      }\n    }\n  }\n}",
                "s3": []
              }
            ],
            "description": null,
            "function_schema": [],
            "id": "O52LVFI8GX,20WLN1NU27,DRAFT",
            "parent_action_group_signature": null,
            "prepare_agent": true,
            "skip_resource_in_use_check": false,
            "timeouts": null
